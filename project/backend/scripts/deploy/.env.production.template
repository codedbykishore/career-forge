# ─────────────────────────────────────────────────────────────────────────────
# CareerForge Production Environment Variables
# Copy this to project/backend/.env and fill in real values
# NEVER commit the actual .env file to git
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_ENV=production
APP_NAME=careerforge
DEBUG=False

# Security — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_SECRET
JWT_SECRET_KEY=REPLACE_WITH_JWT_SECRET

# AWS (IAM role handles auth — no access keys needed on EC2)
USE_DYNAMO=True
AWS_REGION=us-east-1
S3_BUCKET=careerforge-pdfs-602664593597

# Bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# GitHub App
GITHUB_APP_ID=REPLACE_WITH_APP_ID
GITHUB_APP_SLUG=careerforge
GITHUB_APP_CLIENT_ID=REPLACE_WITH_CLIENT_ID
GITHUB_APP_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET
GITHUB_APP_PRIVATE_KEY_SECRET=careerforge/github-app-private-key
GITHUB_CALLBACK_URL=https://REPLACE_WITH_AMPLIFY_URL/api/auth/callback/github

# CORS — Amplify frontend URL (no trailing slash)
ALLOWED_ORIGINS=https://REPLACE_WITH_AMPLIFY_URL

# LaTeX (60s timeout for Bedrock + compile pipeline)
LATEX_COMPILER_TIMEOUT=60
