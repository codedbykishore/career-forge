# Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────
# Local dev: copy to .env.local and fill in values
# Amplify:   set these in Amplify Console → App settings → Environment variables
# ─────────────────────────────────────────────────────────────────

# Backend API (EC2 public IP or domain, no trailing slash)
# Local:      http://localhost:8000
# Production: http://<ec2-public-ip>
NEXT_PUBLIC_API_URL=http://localhost:8000

# GitHub App OAuth — client ID and slug from GitHub Developer Console → Your App
# Required: without these the "Continue with GitHub" / "Connect GitHub" buttons do nothing
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_app_client_id
NEXT_PUBLIC_GITHUB_APP_SLUG=careerforge

# AWS Cognito (Google sign-in)
NEXT_PUBLIC_COGNITO_DOMAIN=careerforge.auth.us-east-1.amazoncognito.com
NEXT_PUBLIC_COGNITO_CLIENT_ID=2lac8ac29r2rnjbkk7q43p1hr2

# The public URL of THIS frontend (used to build the OAuth redirect_uri)
# Local:      http://localhost:3000
# Production: https://<your-amplify-app-id>.amplifyapp.com  (no trailing slash)
# Must match exactly one of the callback URLs registered in GitHub App + Cognito settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
